#!/usr/bin/env sh

# Ensure a recent Node + pnpm are available in PATH.
# Homebrew's node (/opt/homebrew/bin) must come before /usr/local/bin, which
# may hold an old Node (e.g. 20.x) that pnpm 11 refuses to run on (needs >=22.13).
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

pnpm lint
pnpm test:run