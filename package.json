{
    "name": "frontend",
    "version": "0.0.0",
    "type": "module",
    "description": "The Music Assistant frontend developed in Vue.",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "lint": "oxlint && eslint . --fix && pnpm format",
        "lint:check": "oxlint && eslint . && pnpm format:check",
        "lint:oxlint": "oxlint",
        "lint:eslint": "eslint .",
        "format": "prettier --write \"**/*.{js,cjs,ts,vue}\"",
        "format:check": "prettier --check \"**/*.{js,cjs,ts,vue}\"",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky"
    },
